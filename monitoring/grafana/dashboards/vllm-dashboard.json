{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Requests In Flight",
      "description": "Number of requests currently being processed by vLLM",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "vllm:num_requests_running{model_name=\"meta-llama/Llama-3.2-3B-Instruct\"}",
          "legendFormat": "Running",
          "refId": "A"
        },
        {
          "expr": "vllm:num_requests_waiting{model_name=\"meta-llama/Llama-3.2-3B-Instruct\"}",
          "legendFormat": "Waiting (Queued)",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Request Latency (P50 / P95 / P99)",
      "description": "End-to-end request latency percentiles in seconds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vllm:e2e_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Time to First Token (TTFT)",
      "description": "How long until the model starts generating the first token",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "TTFT P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[1m])) by (le))",
          "legendFormat": "TTFT P95",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Token Throughput",
      "description": "Tokens generated and processed per second (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "tokens/s"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(vllm:generation_tokens_total[5m])",
          "legendFormat": "Generation tokens/s",
          "refId": "A"
        },
        {
          "expr": "rate(vllm:prompt_tokens_total[5m])",
          "legendFormat": "Prompt tokens/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "GPU KV Cache Utilization",
      "description": "Percentage of GPU KV cache memory in use. High = near capacity.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          },
          "min": 0,
          "max": 100,
          "unit": "percent"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "vllm:gpu_cache_usage_perc * 100",
          "legendFormat": "KV Cache %",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Success Rate",
      "description": "Rate of successful vs failed requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 20, "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(vllm:request_success_total[1m])",
          "legendFormat": "Success/s",
          "refId": "A"
        },
        {
          "expr": "rate(vllm:request_failure_total[1m])",
          "legendFormat": "Failure/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Request Count (Cumulative)",
      "description": "Total number of requests processed since server start",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "vllm:request_success_total",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Tokens Generated (Cumulative)",
      "description": "Total output tokens generated since server start",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "vllm:generation_tokens_total",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["vllm", "llm", "inference"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "title": "vLLM Inference Monitor",
  "uid": "vllm-inference-monitor"
}
